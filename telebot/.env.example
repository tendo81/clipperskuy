# ClipperSkuy Telebot Configuration

# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Admin Telegram User IDs (comma separated)
ADMIN_IDS=123456789

# License Server
LICENSE_SERVER_URL=https://your-license-server.vercel.app
ADMIN_API_KEY=your_admin_api_key_here

# QRIS Payment (Pakasir) — https://pakasir.com
PAKASIR_SLUG=your_project_slug
PAKASIR_API_KEY=your_pakasir_api_key

# Log Channel ID (optional, negative number for groups/channels)
LOG_CHANNEL_ID=-100123456789

# Product Pricing (in Rupiah)
PRICE_PRO_30=69000
PRICE_PRO_90=179000
PRICE_PRO_365=599000
PRICE_ENTERPRISE_30=150000
PRICE_ENTERPRISE_LIFETIME=999000
